#!/usr/bin/env bash
# ============================================================
#  PRE-PUSH HOOK — FinansIQ
#  Her "git push" öncesinde otomatik çalışır.
#  Build hatası veya bundle boyut ihlali varsa push durur.
# ============================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

PASS="${GREEN}✔${NC}"
FAIL="${RED}✖${NC}"
WARN="${YELLOW}⚠${NC}"
ROOT="$(git rev-parse --show-toplevel)"
ERRORS=0

# Yapılandırma sabitleri
MAX_BUNDLE_KB=600       # JS bundle üst sınırı (KB)
MAX_CSS_KB=50           # CSS bundle üst sınırı (KB)

echo ""
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
echo -e "${BOLD}${CYAN}  PRE-PUSH KONTROL BAŞLIYOR           ${NC}"
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
echo ""

cd "$ROOT"

# ── 1. Uzak branch / hedef kontrol ───────────────────────
echo -e "${BOLD}[1/5] Push hedefi kontrol ediliyor...${NC}"
while read -r local_ref local_sha remote_ref _remote_sha; do
  if echo "$remote_ref" | grep -qE "^refs/heads/(main|master)$"; then
    echo -e "  ${WARN} Ana branch'e (main/master) push yapılıyor — dikkatli ol!"
  fi
done
echo -e "  ${PASS} Hedef branch onaylandı"

# ── 2. Geçmişte kalmış merge conflict ────────────────────
echo -e "${BOLD}[2/5] Tüm kaynak dosyalar taranıyor (conflict)...${NC}"
CONFLICT=$(grep -rEIl "^<<<<<<< |^=======$|^>>>>>>> " "$ROOT/src" 2>/dev/null || true)
if [ -n "$CONFLICT" ]; then
  echo -e "  ${FAIL} Çözülmemiş conflict bulundu:"
  echo "$CONFLICT" | while read -r f; do echo "      → $f"; done
  ERRORS=$((ERRORS + 1))
else
  echo -e "  ${PASS} Conflict işareti yok"
fi

# ── 3. Production build ───────────────────────────────────
echo -e "${BOLD}[3/5] Production build alınıyor...${NC}"
if npm run build > /tmp/finans_build.log 2>&1; then
  echo -e "  ${PASS} Build başarılı"
else
  echo -e "  ${FAIL} Build başarısız — detay:"
  tail -20 /tmp/finans_build.log | while read -r line; do echo "      $line"; done
  ERRORS=$((ERRORS + 1))
fi

# ── 4. Bundle boyut kontrolü ─────────────────────────────
echo -e "${BOLD}[4/5] Bundle boyutları kontrol ediliyor...${NC}"
if [ -d "$ROOT/dist/assets" ]; then
  JS_SIZE_KB=$(find "$ROOT/dist/assets" -name "*.js" | xargs wc -c 2>/dev/null | tail -1 | awk '{printf "%.0f", $1/1024}' || echo "0")
  CSS_SIZE_KB=$(find "$ROOT/dist/assets" -name "*.css" | xargs wc -c 2>/dev/null | tail -1 | awk '{printf "%.0f", $1/1024}' || echo "0")

  if [ "${JS_SIZE_KB:-0}" -gt "$MAX_BUNDLE_KB" ]; then
    echo -e "  ${FAIL} JS bundle çok büyük: ${JS_SIZE_KB}KB (limit: ${MAX_BUNDLE_KB}KB)"
    ERRORS=$((ERRORS + 1))
  else
    echo -e "  ${PASS} JS bundle: ${JS_SIZE_KB}KB / ${MAX_BUNDLE_KB}KB"
  fi

  if [ "${CSS_SIZE_KB:-0}" -gt "$MAX_CSS_KB" ]; then
    echo -e "  ${WARN} CSS bundle büyük: ${CSS_SIZE_KB}KB (limit: ${MAX_CSS_KB}KB)"
  else
    echo -e "  ${PASS} CSS bundle: ${CSS_SIZE_KB}KB / ${MAX_CSS_KB}KB"
  fi
else
  echo -e "  ${WARN} dist/assets bulunamadı — bundle boyutu ölçülemedi"
fi

# ── 5. Paket güvenlik kontrolü (hızlı) ───────────────────
echo -e "${BOLD}[5/5] npm audit (yüksek/kritik zafiyet)...${NC}"
AUDIT_OUT=$(npm audit --audit-level=high --json 2>/dev/null || true)
HIGH=$(echo "$AUDIT_OUT" | grep -o '"high":[0-9]*' | grep -o '[0-9]*' | head -1 || echo "0")
CRIT=$(echo "$AUDIT_OUT" | grep -o '"critical":[0-9]*' | grep -o '[0-9]*' | head -1 || echo "0")

if [ "${HIGH:-0}" -gt 0 ] || [ "${CRIT:-0}" -gt 0 ]; then
  echo -e "  ${FAIL} Güvenlik açığı: high=${HIGH:-0}, critical=${CRIT:-0}"
  echo -e "       ${YELLOW}npm audit fix${NC} komutu ile düzelt"
  ERRORS=$((ERRORS + 1))
else
  echo -e "  ${PASS} Güvenlik açığı yok (high/critical)"
fi

# ── Sonuç ─────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${BOLD}${RED}  ✖ $ERRORS HATA — PUSH DURDURULDU${NC}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
  echo ""
  echo -e "  Zorla push için: ${YELLOW}git push --no-verify${NC}"
  echo ""
  exit 1
else
  echo -e "${BOLD}${GREEN}  ✔ TÜM KONTROLLER GEÇTİ — PUSH ONAYLANDI${NC}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
  echo ""
  exit 0
fi
