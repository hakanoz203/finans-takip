#!/usr/bin/env bash
# ============================================================
#  PRE-COMMIT HOOK — FinansIQ
#  Her commit öncesinde otomatik çalışır.
#  Sorun bulursa commit'i durdurur.
# ============================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

PASS="${GREEN}✔${NC}"
FAIL="${RED}✖${NC}"
WARN="${YELLOW}⚠${NC}"
ROOT="$(git rev-parse --show-toplevel)"
ERRORS=0

echo ""
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
echo -e "${BOLD}${CYAN}  PRE-COMMIT KONTROL BAŞLIYOR         ${NC}"
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
echo ""

# Staged dosyaları bir kez al — boşsa xargs stdin'den okumasın
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

# ── 1. Merge conflict işaretleri ──────────────────────────
echo -e "${BOLD}[1/6] Merge conflict işaretleri kontrol ediliyor...${NC}"
if [ -n "$STAGED_FILES" ]; then
  CONFLICT_FILES=$(echo "$STAGED_FILES" | xargs grep -lP "^<{7} |^={7}$|^>{7} " 2>/dev/null || true)
else
  CONFLICT_FILES=""
fi
if [ -n "$CONFLICT_FILES" ]; then
  echo -e "  ${FAIL} Çözülmemiş conflict bulundu:"
  echo "$CONFLICT_FILES" | while read -r f; do echo "      → $f"; done
  ERRORS=$((ERRORS + 1))
else
  echo -e "  ${PASS} Conflict işareti yok"
fi

# ── 2. Hassas veri / API key taraması ─────────────────────
echo -e "${BOLD}[2/6] Hassas veri taranıyor...${NC}"
# Tek grep ile tüm pattern'ler — 7 process yerine 1
SENSITIVE_PATTERN="(ghp_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{48}|AKIA[A-Z0-9]{16}|password\s*=\s*['\"][^'\"]+['\"]|secret\s*=\s*['\"][^'\"]+['\"]|api[_-]?key\s*=\s*['\"][^'\"]{8,}['\"])"
if [ -n "$STAGED_FILES" ]; then
  SENSITIVE_FOUND=$(echo "$STAGED_FILES" | xargs grep -lEi "$SENSITIVE_PATTERN" 2>/dev/null || true)
else
  SENSITIVE_FOUND=""
fi
if [ -n "$SENSITIVE_FOUND" ]; then
  echo -e "  ${FAIL} Potansiyel hassas veri bulundu:"
  echo "$SENSITIVE_FOUND" | while read -r f; do echo "      → $f"; done
  ERRORS=$((ERRORS + 1))
else
  echo -e "  ${PASS} Hassas veri bulunamadı"
fi

# ── 3. TypeScript tip kontrolü (sadece TS dosyası varsa) ──
echo -e "${BOLD}[3/6] TypeScript tip kontrolü yapılıyor...${NC}"
STAGED_TS=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
cd "$ROOT"
if [ -n "$STAGED_TS" ]; then
  if npx tsc --noEmit --skipLibCheck 2>/dev/null; then
    echo -e "  ${PASS} TypeScript hata yok"
  else
    echo -e "  ${FAIL} TypeScript hataları var — ${YELLOW}npx tsc --noEmit${NC} ile detay gör"
    ERRORS=$((ERRORS + 1))
  fi
else
  echo -e "  ${PASS} TS dosyası yok — atlandı"
fi

# ── 4. ESLint kontrolü ────────────────────────────────────
echo -e "${BOLD}[4/6] ESLint kontrol ediliyor...${NC}"
if [ -n "$STAGED_TS" ]; then
  # Quoted array — boşluk içeren yollar güvenli
  mapfile -t TS_ARRAY <<< "$STAGED_TS"
  if npx eslint "${TS_ARRAY[@]}" --max-warnings=0 2>/dev/null; then
    echo -e "  ${PASS} ESLint temiz"
  else
    echo -e "  ${WARN} ESLint uyarıları var (commit devam edecek)"
  fi
else
  echo -e "  ${PASS} Kontrol edilecek TS dosyası yok"
fi

# ── 5. console.log / debugger kalıntısı ───────────────────
echo -e "${BOLD}[5/6] Debug kalıntıları kontrol ediliyor...${NC}"
if [ -n "$STAGED_FILES" ]; then
  DEBUG_FILES=$(echo "$STAGED_FILES" | xargs grep -lE "console\.(log|debug|warn|error)\s*\(|debugger;" 2>/dev/null || true)
else
  DEBUG_FILES=""
fi
if [ -n "$DEBUG_FILES" ]; then
  echo -e "  ${WARN} console.log / debugger bulundu (commit devam edecek):"
  echo "$DEBUG_FILES" | while read -r f; do echo "      → $f"; done
else
  echo -e "  ${PASS} Debug kalıntısı yok"
fi

# ── 6. Büyük dosya kontrolü (>1MB) ───────────────────────
echo -e "${BOLD}[6/6] Büyük dosya kontrolü (<1MB sınırı)...${NC}"
BIG_FILES=$(echo "$STAGED_FILES" | while read -r f; do
  [ -f "$f" ] || continue
  SIZE=$(wc -c < "$f" 2>/dev/null || echo 0)
  [ "${SIZE:-0}" -gt 1048576 ] && echo "$f ($(( SIZE / 1024 ))KB)"
done || true)

if [ -n "$BIG_FILES" ]; then
  echo -e "  ${FAIL} Büyük dosyalar bulundu:"
  echo "$BIG_FILES" | while read -r f; do echo "      → $f"; done
  ERRORS=$((ERRORS + 1))
else
  echo -e "  ${PASS} Tüm dosyalar boyut limitinde"
fi

# ── Sonuç ─────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${BOLD}${RED}  ✖ $ERRORS HATA — COMMIT DURDURULDU${NC}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
  echo ""
  exit 1
else
  echo -e "${BOLD}${GREEN}  ✔ TÜM KONTROLLER GEÇTİ — COMMIT ONAYLANDI${NC}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════${NC}"
  echo ""
  exit 0
fi
